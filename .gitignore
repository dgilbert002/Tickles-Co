# ============================================================================
# Tickles-Co .gitignore
# Root-level ignore rules for the whole /opt/tickles workspace mirror.
# Merges the VPS /opt/tickles/.gitignore with the local additions.
# ============================================================================

# --- Python runtime ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# --- Virtual environments (VPS .venv, local dev venvs) ---
.venv/
venv/
env/

# --- Secrets (NEVER commit) ---
.env
.env.*
!.env.template
!.env.example
*.key
*.pem
.git-credentials
credentials.json
secrets.json

# Collector configs with secrets (same rule as VPS)
shared/collectors/discord/data/discord_config.json
shared/collectors/telegram/data/telegram_config.json
shared/collectors/telegram/data/*.session

# --- Paperclip workspace runtime (not code, lives on VPS only) ---
backups/
data/
projects/*/logs/
projects/*/config/local*
projects/*/node_modules/

# --- Platform runtime artifacts (regenerated, not source) ---
shared/backtests.txt
shared/.backtests_state.json
shared/data/
shared/logs/

# --- Logs & dumps ---
logs/
*.log
*.sql.bak

# --- OSS reference clones (Phase 12.9 of master plan — local-only) ---
_references/

# --- Build artifacts ---
build/
dist/
*.whl
*.zip
*.tar.gz

# --- IDE / OS cruft ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Paperclip tsx build cache ---
.paperclip-cache/
*.tsbuildinfo

# --- Audit / scratch outputs (Phase 0 — contain host state, possible tokens) ---
shared/docs/_audit_*.txt
shared/docs/_audit_*.md
_audit_*.txt
_audit_*.md

# --- Reference chat logs containing exposed third-party API keys (Phase 0) ---
# The OpenRouter premium-model chats embedded live Aster/Bybit/etc keys and
# configs; keep locally for reference but never commit.
shared/docs/OpenRouter_Chats.md
shared/docs/OpenClaw Trading Systems.txt
shared/docs/Top wallets capture 86% of the move.txt
shared/docs/PHASE_39_DRILL*.json

# --- OTP / auth debug logs (contain Telegram 2FA codes, expire in 5 min) ---
_otp_log.jsonl
_otp_log_*.jsonl

# --- Secret-prone ad-hoc scripts (safety net; real keys live in /root/.bashrc) ---
# Any script named *.secret.sh, or test_* scripts under _rubicon_deploy that
# might inline credentials during debugging, must not reach the remote.
# We intentionally whitelist the redacted test_openrouter.sh (which now reads
# the key from $OPENROUTER_API_KEY).
*.secret.sh
_rubicon_deploy/test_*.local.sh
_tmp_*secret*.sh

# --- Explicit includes (override broader patterns above) ---
!shared/migration/*.sql
!shared/migration/*.py
!shared/utils/*.py

# OpenMemory - IDE/Assistant specific rules
.cursor\rules\openmemory.mdc
CLAUDE.md
